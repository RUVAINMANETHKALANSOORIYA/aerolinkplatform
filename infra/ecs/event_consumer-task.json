{
  "family": "aerolink-event-consumer",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::123456789012:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::123456789012:role/aerolinkEventConsumerTaskRole",
  "containerDefinitions": [
    {
      "name": "event_consumer",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/aerolink/event-consumer:latest",
      "essential": true,
      "environment": [
        { "name": "RABBITMQ_URL", "value": "amqp://guest:guest@rabbitmq:5672/" },
        { "name": "LOG_LEVEL", "value": "info" }
      ],
      "command": ["python", "consumer.py"],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aerolink/event_consumer",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}