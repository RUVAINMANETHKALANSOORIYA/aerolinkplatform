# AeroLink frontend environment variables — ECS + Cognito
#
# Copy this file to .env.local and fill in real values.
# .env.local is ignored by git (covered by *.local in .gitignore).
# Do NOT commit .env.local.

# Base URL of the ECS Application Load Balancer (no trailing slash).
# Example: http://aerolink-alb-1234567890.us-east-1.elb.amazonaws.com
VITE_API_BASE_URL=http://<YOUR_ECS_ALB_DNS>

# AWS region where your Cognito User Pool lives.
VITE_AWS_REGION=us-east-1

# Cognito User Pool ID (format: <region>_<alphanumeric>).
# Example: us-east-1_hpW84ZtH4
VITE_COGNITO_USER_POOL_ID=<YOUR_COGNITO_USER_POOL_ID>

# Cognito App Client ID (no client secret for public SPA clients).
# Example: 14hg3aomr5krmmac2ivh7q25bv
VITE_COGNITO_APP_CLIENT_ID=<YOUR_COGNITO_APP_CLIENT_ID>
